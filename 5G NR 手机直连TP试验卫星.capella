          <ownedConstraints xsi:type="org.polarsys.capella.core.data.capellacore:Constraint"
              id="5bc91294-29cc-4808-a34b-b5445eef5759" name="反向开环增益补偿&#xD;&#xA;支持根据接收相控阵波束指向，自动对反向接收信号进行放大增益控制，补偿不同指向下天线增益差异，或补偿不同指向下天线增益差异+路径传输损耗差异，使反向链路工作于额定工作点（该控制逻辑支持软件或参数重构修改）；&#xD;&#xA;补偿误差≤1dB"
              constrainedElements="#c195d0ef-6107-482b-bac3-5166a746dade">
            <ownedSpecification xsi:type="org.polarsys.capella.core.data.information.datavalue:OpaqueExpression"
                id="d7bab9ae-7969-4be1-9a12-6adb2f9dd16b">
              <bodies></bodies>
              <languages>capella:linkedText</languages>
            </ownedSpecification>
          </ownedConstraints>
          <ownedConstraints xsi:type="org.polarsys.capella.core.data.capellacore:Constraint"
              id="08bc256d-f5b0-4c25-93a0-ecfb89f20cbc" name="反向业务额定输入控制&#xD;&#xA;1.支持通过指令控制反向链路额定输入功率点（额定输入通量密度点定义为达到额定输出所需的输入激励）；&#xD;&#xA;2.反向额定输入通量密度可控；&#xD;&#xA;3.额定输入通量密度控制精度优于1dB；&#xD;&#xA;4.随路遥测信号的输出不随业务信号额定输入点调整而变化。&#xD;&#xA;"
              constrainedElements="#c195d0ef-6107-482b-bac3-5166a746dade">
            <ownedSpecification xsi:type="org.polarsys.capella.core.data.information.datavalue:OpaqueExpression"
                id="76c260ea-d9ea-462d-ac2d-331fa544e1c0">
              <bodies></bodies>
              <languages>capella:linkedText</languages>
            </ownedSpecification>
          </ownedConstraints>
          <ownedConstraints xsi:type="org.polarsys.capella.core.data.capellacore:Constraint"
              id="8ca8891b-cfd2-4fde-9ef0-3153bd1ac6e4" name="前向自动增益控制&#xD;&#xA;1.支持对馈电接收信号进行闭环自动增益控制，适应不同输入功率，使前向链路各个用户波束工作于额定工作点；&#xD;&#xA;2.馈电天线口面接收信号功率通量密度在一定范围内变化。&#xD;&#xA;"
              constrainedElements="#c195d0ef-6107-482b-bac3-5166a746dade">
            <ownedSpecification xsi:type="org.polarsys.capella.core.data.information.datavalue:OpaqueExpression"
